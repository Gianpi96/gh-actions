# Copy to .env — never commit .env itself

APP_NAME=fastapi-app
ENVIRONMENT=development
LOG_LEVEL=INFO
DEBUG=false

DATABASE_URL=postgresql+asyncpg://postgres:1234@localhost:5432/appdb
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_ECHO=false

REDIS_URL=redis://localhost:6379

GROQ_API_KEY=gsk_...
GROQ_MODEL=llama-3.3-70b-versatile

SENTRY_DSN=
ENABLE_METRICS=true
